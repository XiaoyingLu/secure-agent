# Required: Entra tenant hosting your app registration
VITE_ENTRA_TENANT_ID=

# Required: Public SPA app registration client ID
VITE_ENTRA_CLIENT_ID=

# Required: Delegated scope exposed by the API app registration.
# Example: api://<api-app-client-id>/access_as_user
VITE_API_SCOPE=

# Optional: backend URL in production (leave empty in local dev to use Vite proxy)
VITE_API_BASE_URL=

# Optional: local dev backend target for Vite proxy
VITE_DEV_BACKEND_URL=http://127.0.0.1:8000
